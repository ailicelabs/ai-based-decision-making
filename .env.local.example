# --- OpenAI ---
OPENAI_API_KEY=sk-...
# Il modello deve supportare le immagini (vision). gpt-4o va bene.
OPENAI_MODEL=gpt-4o
# Temperatura 0–1 (più bassa = risposte più coerenti). Default 0.5.
OPENAI_TEMPERATURE=0.5

# --- Sessione: stringa casuale lunga per firmare il cookie ---
SESSION_SECRET=cambia-questa-stringa-con-una-casuale

# --- Codici di accesso (opachi: NON devono rivelare il gruppo) ---
ACCESS_CODE_GROUP_A=alpha-7421
ACCESS_CODE_GROUP_B=bravo-3856
ACCESS_CODE_GROUP_C=charlie-9012
ACCESS_CODE_GROUP_D=delta-6473

# --- Database (in locale opzionale; su Vercel lo crea l'integrazione Neon) ---
# Se assente, il log delle conversazioni viene disattivato.
# DATABASE_URL=postgres://...
